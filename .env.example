# Telegram Bot Token (Get this from @BotFather)
TELOXIDE_TOKEN=your_telegram_bot_token_here

# OpenCode Server URL (Optional, defaults to http://127.0.0.1:4096)
OPENCODE_SERVER_URL=http://127.0.0.1:4096

# Default working directory for the bot (Optional)
# OPENCODE_DEFAULT_DIR=/path/to/your/projects

# Access Control
# Set to '*' to allow anyone, or a comma-separated list of Telegram User IDs (e.g. '123456789,987654321')
# Users can message @userinfobot to find their ID.
ALLOWED_USERS=*
UNAUTHORIZED_MESSAGE="🚫 You are not authorized to use this bot. Please contact the administrator or use @userinfobot to get your Telegram ID and add it to ALLOWED_USERS."

# Group Logic
# Whether the bot is allowed to operate in group chats.
ALLOW_IN_GROUPS=true
GOOGLE_SPEECH_API_KEY=