# Telegram Bot Token (from @BotFather)
TELEGRAM__TOKEN=your_bot_token_here

# Allowed Telegram User ID (from @userinfobot)
TELEGRAM__ALLOWED_USER_ID=your_user_id_here

# Telegram Proxy URL (optional)
# Supports socks5://, socks4://, http://, https:// protocols
# TELEGRAM__PROXY_URL=socks5://user:pass@proxy.example.com:1080

# OpenCode API Configuration
OPENCODE__API_URL=http://localhost:4096
OPENCODE__USERNAME=opencode
# OPENCODE__PASSWORD=your_password_here
OPENCODE__MODEL_PROVIDER=opencode
OPENCODE__MODEL_ID=big-pickle

# Server Configuration
SERVER__LOG_LEVEL=info
SERVER__LOG_RETENTION=10

# Bot Configuration
BOT__SESSIONS_LIST_LIMIT=10
BOT__PROJECTS_LIST_LIMIT=10
BOT__COMMANDS_LIST_LIMIT=10
BOT__TASK_LIMIT=10
BOT__RESPONSE_STREAM_THROTTLE_MS=500
BOT__BASH_TOOL_DISPLAY_MAX_LENGTH=128
BOT__LOCALE=en
BOT__HIDE_THINKING_MESSAGES=false
BOT__HIDE_TOOL_CALL_MESSAGES=false
BOT__MESSAGE_FORMAT_MODE=markdown

# File Configuration
FILES__MAX_FILE_SIZE_KB=100

# Speech-to-Text Configuration (optional)
# STT__API_URL=https://api.openai.com/v1
# STT__API_KEY=your_stt_api_key
# STT__MODEL=whisper-large-v3-turbo
# STT__LANGUAGE=en

# Text-to-Speech Configuration (optional)
# TTS__API_URL=https://api.openai.com/v1
# TTS__API_KEY=your_tts_api_key
# TTS__MODEL=gpt-4o-mini-tts
# TTS__VOICE=alloy

# Directory Browser Roots (optional)
# OPEN__BROWSER_ROOTS=~/projects,~/work
