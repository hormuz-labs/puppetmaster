# Telegram Bot Token (Get this from @BotFather)
TELOXIDE_TOKEN=your_telegram_bot_token_here

# OpenCode Server URL (Optional, defaults to http://127.0.0.1:4096)
OPENCODE_SERVER_URL=http://127.0.0.1:4096

# Default working directory for the bot (Optional)
# OPENCODE_DEFAULT_DIR=/path/to/your/projects
